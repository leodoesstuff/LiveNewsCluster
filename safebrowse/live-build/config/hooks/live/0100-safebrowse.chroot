#!/usr/bin/env bash
set -e
id -u user >/dev/null 2>&1 || useradd -m -u 1000 -s /bin/bash user
systemctl enable tor
systemctl enable nftables
systemctl enable safebrowse-kiosk.service
TOR_UID="$(id -u debian-tor)"
sed -i "s/^define TOR_UID = .*/define TOR_UID = ${TOR_UID}/" /etc/nftables.conf
swapoff -a || true
